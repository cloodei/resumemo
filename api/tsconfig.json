{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"],
      "@/*": ["../web/src/*"],
      "@resumemo/core": ["../core/src"],
      "@resumemo/core/*": ["../core/src/*"]
    },
    "jsx": "react",
    "types": ["bun-types"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "src/**/**/*", "index.ts", "drizzle.config.ts"]
}
