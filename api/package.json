{
  "name": "api",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "./main",
    "build": "bun build --compile --minify --outfile main index.ts",
    "push": "bunx --bun drizzle-kit push",
    "generate": "bunx --bun @better-auth/cli generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.990.0",
    "@aws-sdk/s3-request-presigner": "^3.990.0",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@resumemo/core": "*",
    "amqplib": "^0.10.9",
    "better-auth": "^1.4.18",
    "elysia": "^1.4.25",
    "postgres": "^3.4.8",
    "wrangler": "4.35.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "bun-types": "^1.3.10",
    "drizzle-kit": "^0.31.9"
  }
}
